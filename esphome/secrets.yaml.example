# Copy to secrets.yaml and fill in your values.
# secrets.yaml is gitignored — never commit real credentials.

# --- WiFi (all nodes) ---
wifi_ssid: "your_wifi_ssid"
wifi_password: "your_wifi_password"

# --- Mower BLE MAC ---
# The mower is identified by its BLE MAC. Find it with a phone BLE scanner
# (e.g. nRF Connect) or by watching a node's logs with BLE Scanning on.
luba_mac: "AA:BB:CC:DD:EE:FF"

# --- OTA + fallback hotspot passwords (set your own — do not keep these) ---
ota_password: "CHANGE_ME_ota_password"
fallback_password: "CHANGE_ME_fallback_password"

# --- Native API encryption keys (one per node) ---
# Generate each with: esphome generate-api-key
api_key_front: "YOUR_API_KEY_FRONT="
api_key_back: "YOUR_API_KEY_BACK="
api_key_gate: "YOUR_API_KEY_GATE="
